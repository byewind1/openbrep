#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -d "$ROOT_DIR/frontend" && -f "$ROOT_DIR/openbrep/workbench_api.py" ]]; then
  APP_DIR="$ROOT_DIR"
elif [[ -d "$ROOT_DIR/.worktrees/react-workbench-poc/frontend" ]]; then
  APP_DIR="$ROOT_DIR/.worktrees/react-workbench-poc"
else
  echo "[obr7] React Workbench not found."
  echo "[obr7] Expected either ./frontend or ./.worktrees/react-workbench-poc/frontend"
  exit 1
fi

if [[ ! -d "$APP_DIR/frontend/node_modules" ]]; then
  echo "[obr7] frontend/node_modules not found. Run:"
  echo "       cd \"$APP_DIR/frontend\" && npm install"
  exit 1
fi

exec python "$APP_DIR/scripts/obr7.py" "$@"
